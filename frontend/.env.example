VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API Base URL — used by the frontend to reach the backend
# Development: http://localhost:8000/api (direct to Django)
#             or /api (uses Vite proxy — matches vite.config.ts)
# Production:  set to full URL or /api if behind a reverse proxy
VITE_API_BASE_URL=http://localhost:8000/api
